{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dot-agent-deck-gui",
  "version": "0.1.0",
  "identifier": "ai.devopstoolkit.agent-deck.gui",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "dot-agent-deck",
        "width": 1000,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
